# 1. DATABASE (SUPABASE)
# Gunakan Transaction Connection Pooler dari Supabase (Port 6543)
# Pastikan ada akhiran ?pgbouncer=true&connection_limit=1
DATABASE_URI=postgresql://postgres.your_project_ref:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# 2. PAYLOAD SECURITY
PAYLOAD_SECRET=YOUR_SECRET_HERE

# 3. STORAGE MEDIA (CLOUDFLARE R2)
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# 4. SERVER CONFIG
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
